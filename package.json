{
  "name": "electron-manager",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @electron-manager/desktop dev",
    "start": "pnpm --filter @electron-manager/desktop start",
    "build": "pnpm --filter @electron-manager/project-core build && pnpm --filter @electron-manager/desktop build",
    "prepare:mac": "pnpm build && node scripts/prepare-mac-app.mjs",
    "pack:mac": "pnpm prepare:mac && electron-builder --mac --dir && node scripts/sign-mac-app.mjs",
    "dist:mac": "pnpm pack:mac && node scripts/create-mac-zip.mjs",
    "dmg:mac": "pnpm pack:mac && node scripts/create-mac-dmg.mjs",
    "test": "node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "electron-builder": "^26.15.3",
    "typescript": "~6.0.2"
  }
}
